# Container image selection
DISCOVERY_IMAGE_REPOSITORY=ghcr.io/YOUR_GITHUB_OWNER/discovery_system
DISCOVERY_IMAGE_TAG=latest

# Runtime mode
DISCOVERY_APP_ENV=production
DISCOVERY_APP_BASE_URL=https://discovery.example.com
DISCOVERY_AUTO_APPLY_MIGRATIONS=false
DISCOVERY_HOST_PORT=8000
PORT=8000
WEB_CONCURRENCY=1

# Persistent server storage
DISCOVERY_PERSISTENT_DATA_DIR=/srv/discovery-intelligence/data
DISCOVERY_POSTGRES_DATA_DIR=/srv/discovery-intelligence/postgres
DISCOVERY_ALLOWED_ARTIFACT_ROOTS=/app/data

# Database
DISCOVERY_POSTGRES_DB=discovery
DISCOVERY_POSTGRES_USER=discovery
DISCOVERY_POSTGRES_PASSWORD=CHANGE_ME_DB_PASSWORD
DISCOVERY_DATABASE_URL=postgresql+psycopg://discovery:CHANGE_ME_DB_PASSWORD@db:5432/discovery

# Session/auth security
DISCOVERY_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
DISCOVERY_SESSION_SECURE=true
DISCOVERY_SESSION_SAME_SITE=lax
DISCOVERY_SESSION_MAX_AGE_SECONDS=28800

# Bootstrap admin identity for first startup only
DISCOVERY_BOOTSTRAP_EMAIL=admin@example.com
DISCOVERY_BOOTSTRAP_PASSWORD=CHANGE_ME_NOW
DISCOVERY_BOOTSTRAP_WORKSPACE=Discovery Internal
DISCOVERY_BOOTSTRAP_NAME=Admin

# Optional deploy-time health verification
DISCOVERY_HEALTHCHECK_URL=https://discovery.example.com/healthz

# Paddle billing
PADDLE_ENVIRONMENT=sandbox
PADDLE_API_KEY=CHANGE_ME_PADDLE_API_KEY
PADDLE_WEBHOOK_SECRET=CHANGE_ME_PADDLE_WEBHOOK_SECRET
PADDLE_PRO_PRICE_ID=pri_CHANGE_ME
PADDLE_CHECKOUT_URL=
PADDLE_BILLING_RETURN_URL=https://discovery.example.com/billing
PADDLE_WEBHOOK_TOLERANCE_SECONDS=300
